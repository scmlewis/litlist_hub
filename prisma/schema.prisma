generator client {
  provider = "prisma-client-js"
}

// Use PostgreSQL for production (Neon)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  lists         List[]
  readingGoals  ReadingGoal[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App-specific models
model Book {
  id             String     @id @default(cuid())
  openLibraryKey String     @unique
  title          String
  authors        String     @default("[]") // JSON array stored as string for SQLite
  coverUrl       String?
  publishYear    Int?
  isbn           String?
  pageCount      Int?
  listBooks      ListBook[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model List {
  id        String     @id @default(cuid())
  name      String
  shareId   String     @unique @default(cuid())
  isPublic  Boolean    @default(false)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  books     ListBook[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model ListBook {
  id          String    @id @default(cuid())
  status      String    @default("WANT_TO_READ") // WANT_TO_READ, READING, DONE
  notes       String?
  review      String?   // User's review of the book
  rating      Int?      // 1-5 star rating
  currentPage Int?      // Current reading progress
  totalPages  Int?      // Total pages (can override book.pageCount)
  startDate   DateTime? // When started reading
  finishDate  DateTime? // When finished reading
  order       Int       @default(0) // Custom order within list (for drag-and-drop)
  listId      String
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([listId, bookId])
  @@index([listId])
  @@index([bookId])
  @@index([listId, order])
}

model ReadingGoal {
  id        String   @id @default(cuid())
  year      Int
  target    Int      // Number of books to read
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
  @@index([userId])
}
